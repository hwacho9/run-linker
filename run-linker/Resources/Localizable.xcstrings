        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "랜덤 매칭으로\n새로운 자극"
          }
        }
      }
    },
    "onboarding.step3.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Track your personal growth with a personalized dashboard and build a joyful running life."
          }
