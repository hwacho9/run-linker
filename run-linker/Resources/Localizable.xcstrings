    "onboarding.step1.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feel your friend's pace through real-time location sync and experience the joy of running together anywhere in the world."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リアルタイムの位置同期で友だちのペースを感じながら、世界中どこにいても一緒に走る楽しさを体験しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "실시간 위치 동기화로 친구의 페이스를 느끼며 전 세계 어디서든 함께 뛰는 즐거움을 경험하세요."
          }
        }
      }
    },
    "onboarding.step1.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Together even\nwhen apart"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "離れていても\n一緒に走る"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "멀리 있어도\n함께 달리는 우리"
          }
        }
      }
    },
    "onboarding.step2.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enjoy a new running experience with runners at a similar pace through privacy-safe random matching."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーを守るランダムマッチで、自分と近いペースのランナーと新しいランニング体験を楽しみましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "프라이버시가 보호되는 랜덤 매칭으로 나와 비슷한 페이스의 러너와 새로운 달리기 경험을 즐겨보세요."
          }
        }
      }
    },
    "onboarding.step2.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
