    "auth.error.account_exists_different_credential": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This email is already registered with a different sign-in method."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동일한 이메일로 다른 로그인 방식이 이미 등록되어 있습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このメールアドレスは別のログイン方法ですでに登録されています。"
          }
        }
      }
    },
    "auth.error.all_fields_required": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please fill in all fields."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 필드를 입력해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての項目を入力してください。"
          }
        }
      }
    },
    "auth.error.app_check_failed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Firebase App Check failed. Check simulator debug token registration or App Check enforcement."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Firebase App Check 검증에 실패했습니다. 시뮬레이터 debug token 등록 또는 App Check enforcement 설정을 확인해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Firebase App Check の検証に失敗しました。シミュレーターの debug token 登録または App Check enforcement 設定を確認してください。"
          }
        }
      }
    },
    "auth.error.apple_credential_processing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An error occurred while processing Apple credentials."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 자격 증명 처리 중 오류가 발생했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 認証情報の処理中にエラーが発生しました。"
          }
        }
      }
    },
    "auth.error.apple_credential_unreadable": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not read Apple credentials."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 인증 정보를 읽지 못했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 認証情報を読み取れませんでした。"
          }
        }
      }
    },
    "auth.error.apple_device_not_configured": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device is not configured for the required Apple authentication."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서는 필요한 Apple 인증 설정이 완료되지 않았습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスでは必要な Apple 認証設定が完了していません。"
          }
        }
      }
    },
    "auth.error.apple_excluded_credential": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Apple credential cannot be used on this device."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서 사용할 수 없는 Apple 자격 증명입니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Apple 認証情報はこのデバイスでは使用できません。"
          }
        }
      }
    },
    "auth.error.apple_failed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple sign-in failed. Please try again later."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인에 실패했습니다. 잠시 후 다시 시도해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleでのサインインに失敗しました。しばらくしてからもう一度お試しください。"
          }
        }
      }
    },
    "auth.error.apple_generic": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An error occurred during Apple sign-in."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인 중 오류가 발생했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleでのサインイン中にエラーが発生しました。"
          }
        }
      }
    },
    "auth.error.apple_invalid_response": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Apple authentication response is invalid."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 인증 응답이 올바르지 않습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 認証の応答が無効です。"
          }
        }
      }
    },
    "auth.error.apple_nonce_missing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple sign-in request state was lost. Please try again."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인 요청 상태가 유실되었습니다. 다시 시도해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple サインインのリクエスト状態が失われました。もう一度お試しください。"
          }
        }
      }
    },
    "auth.error.apple_not_handled": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not handle the Apple sign-in request."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인 요청을 처리하지 못했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple サインインのリクエストを処理できませんでした。"
          }
        }
      }
    },
    "auth.error.apple_not_interactive": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple sign-in cannot continue in the current state."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 상태에서는 Apple 로그인을 진행할 수 없습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の状態では Apple サインインを続行できません。"
          }
        }
      }
    },
    "auth.error.apple_preferred": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with Apple is recommended for this account."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 계정은 Apple 로그인을 사용하는 것이 권장됩니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントでは Apple でのサインインをおすすめします。"
          }
        }
      }
    },
    "auth.error.apple_token_missing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not get the Apple authentication token."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 인증 토큰을 가져오지 못했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 認証トークンを取得できませんでした。"
          }
        }
      }
    },
    "auth.error.apple_unknown": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An unknown Apple sign-in error occurred."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인 중 알 수 없는 오류가 발생했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple サインイン中に不明なエラーが発生しました。"
          }
        }
      }
    },
    "auth.error.credential_already_in_use": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This sign-in method is already linked to another account."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 다른 계정에 연결된 로그인 수단입니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このログイン方法はすでに別のアカウントに連携されています。"
          }
        }
      }
    },
    "auth.error.email_already_in_use": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This email is already registered."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 가입된 이메일입니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このメールアドレスはすでに登録されています。"
          }
        }
      }
    },
    "auth.error.email_password_required": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please enter your email and password."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이메일과 비밀번호를 입력해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メールアドレスとパスワードを入力してください。"
          }
        }
      }
    },
    "auth.error.firestore_database_missing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The default Firestore database has not been created yet. Create Firestore Database in Firebase Console and try again."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore 기본 데이터베이스가 아직 생성되지 않았습니다. Firebase Console에서 Firestore Database를 만든 뒤 다시 시도해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトの Firestore データベースがまだ作成されていません。Firebase Console で Firestore Database を作成してからもう一度お試しください。"
          }
        }
      }
    },
    "auth.error.firestore_permission_denied": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore security rules do not allow saving users/profiles. Allow signed-in users to write their own documents."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore 보안 규칙이 users/profiles 저장을 허용하지 않습니다. 로그인한 사용자가 본인 문서에 쓸 수 있도록 rules를 확인해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore セキュリティルールにより users/profiles の保存が許可されていません。ログイン中のユーザーが自分のドキュメントに書き込めるよう rules を確認してください。"
          }
        }
      }
    },
    "auth.error.firestore_write_timeout": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore user profile save is taking too long. Check Firestore Database, security rules, App Check, and network status, then try logging in again."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore 사용자 프로필 저장이 지연되고 있습니다. Firestore Database, 보안 규칙, App Check, 네트워크 상태를 확인한 뒤 다시 로그인해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Firestore のユーザープロフィール保存に時間がかかっています。Firestore Database、セキュリティルール、App Check、ネットワーク状態を確認してから再度ログインしてください。"
          }
        }
      }
    },
    "auth.error.google_config_missing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Google sign-in is not configured. Check GoogleService-Info.plist and URL Scheme."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Google 로그인 설정이 누락되었습니다. GoogleService-Info.plist와 URL Scheme를 확인해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Google ログイン設定が不足しています。GoogleService-Info.plist と URL Scheme を確認してください。"
          }
        }
      }
    },
    "auth.error.google_present_failed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not open the Google sign-in screen."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Google 로그인 화면을 열 수 없습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Google ログイン画面を開けませんでした。"
          }
        }
      }
    },
    "auth.error.google_token_missing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not get the Google authentication token."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Google 인증 토큰을 가져올 수 없습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Google 認証トークンを取得できませんでした。"
          }
        }
      }
    },
    "auth.error.invalid_credential": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The credential is invalid. Please try again."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인증 정보가 유효하지 않습니다. 다시 시도해주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証情報が無効です。もう一度お試しください。"
          }
        }
      }
    },
    "auth.error.invalid_email": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The email format is invalid."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이메일 형식이 올바르지 않습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
