    },
    "auth.error.login_cancelled": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign-in was cancelled."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인이 취소되었습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインがキャンセルされました。"
          }
