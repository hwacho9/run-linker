    },
    "auth.error.invalid_email_format": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please enter a valid email address."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
